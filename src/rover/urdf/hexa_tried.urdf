<?xml version='1.0'?>
<robot name="hexa_body">
  <link name="base_footprint"/>

<joint name="base_footprint_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>
  <link name="base_link">
    <visual>
      <geometry>
          <box size=".2 0.2 0.1"/>
      </geometry>
      <material name="gray">
        <color rgba=".2 .2 .2 1" />
      </material>
    </visual>
  <inertial>
            <mass value="2" />
            <inertia ixx="0.04" ixy="0.0" ixz="0" 
            iyy="0.17" iyz="0" izz="0.25" />
    </inertial>
    
    <collision>
      <geometry>
          <box size=".2 0.2 0.1"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_front_right">
    <inertial>
            <mass value="2" />
            <inertia ixx="1e-3" ixy="0.0" ixz="0" 
            iyy="1e-3" iyz="0" izz="1e-3" />
    </inertial>

    <visual>
      
      <geometry>
          <cylinder radius="0.05" length="0.06"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision>
    
      <geometry>
          <cylinder radius="0.05" length="0.06"/>
      </geometry>
      <contact_coefficients mu="1" kp="1e+13" kd="1.0"/>
    </collision>
  </link>

  <joint name="wheel_front_right_joint" type="continuous">
    <origin xyz="0 0.15 -0.05" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_front_right"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <link name="wheel_front_left">
    <inertial>
            <mass value="2" />
            <inertia ixx="1e-3" ixy="0.0" ixz="0" 
            iyy="1e-3" iyz="0" izz="1e-3" />
    </inertial>

    <visual>
      
      <geometry>
          <cylinder radius="0.05" length="0.06"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
          <cylinder radius="0.05" length="0.06"/>
      </geometry>
      <contact_coefficients mu="1" kp="1e+13" kd="1.0"/>
    </collision>
  </link>

  <joint name="wheel_front_left_joint" type="continuous">
    <origin xyz="0 -0.15 -0.05" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_front_left"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

  <link name="front_castor_wheel">
    <inertial>
            <mass value="2" />
            <inertia ixx="1e-3" ixy="0.0" ixz="0" 
            iyy="1e-3" iyz="0" izz="1e-3" />
    </inertial>

    <visual>
      
      <geometry>
          <sphere radius="0.05"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
          <sphere radius="0.05"/>
      </geometry>
      <contact_coefficients mu="1" kp="1e+13" kd="1.0"/>
    </collision>
  </link>

  <joint name="castor_wheel_joint" type="fixed">
    <origin xyz="-0.15 0 -0.048" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="front_castor_wheel"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

  <link name="back_castor_wheel">
    <inertial>
            <mass value="2" />
            <inertia ixx="1e-3" ixy="0.0" ixz="0" 
            iyy="1e-3" iyz="0" izz="1e-3" />
    </inertial>

    <visual>
      
      <geometry>
          <sphere radius="0.05"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
          <sphere radius="0.05"/>
      </geometry>
      <contact_coefficients mu="1" kp="1e+13" kd="1.0"/>
    </collision>
  </link>

  <joint name="castor_wheel_joint_2" type="fixed">
    <origin xyz="0.15 0 -0.048" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="back_castor_wheel"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>


  <link name="camera">
    <inertial>
            <mass value="0.5" />
            <inertia ixx="0.01" ixy="0.0" ixz="0" 
            iyy="0.01" iyz="0" izz="0.01" />
    </inertial>

    <visual>
      
      <geometry>
        <box size="0.025 0.09 0.025"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
          <box size="0.025 0.09 0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="-0.1 0 0.4" rpy="0 0.0 3.14"/>
    <parent link="base_link"/>
    <child link="camera"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

  <link name="lidar">
    <inertial>
            <mass value="0.5" />
            <inertia ixx="0.01" ixy="0.0" ixz="0" 
            iyy="0.01" iyz="0" izz="0.01" />
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0  1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 0.5" rpy="0 0.0 1.57"/>
    <parent link="base_link"/>
    <child link="lidar"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>  

    <link name="camera_link_optical"/>

    <joint name="camera_optical_joint" type="fixed">
    <parent link="camera"/>
    <child link="camera_link_optical"/>
    <origin xyz="0 0 0.5"
            rpy="-1.5708 0 -1.5708"/>
    </joint>

    <link name="imu_link">
  <inertial>
    <mass value="0.1"/>
    <inertia ixx="1e-5" ixy="0.0" ixz="0.0"
             iyy="1e-5" iyz="0.0"
             izz="1e-5"/>
  </inertial>
</link>

<joint name="imu_joint" type="fixed">
  <parent link="base_link"/>
  <child link="imu_link"/>
  <origin xyz="0 0 0.2" rpy="0 0 0"/>
</joint>

<!-- DIFFENERNTIAL DRIVEEEEEEEEEEEEE -->

<gazebo>
<!-- <plugin name='diff_drive' filename='libgazebo_ros_diff_drive.so'>
        <left_joint>wheel_front_left_joint</left_joint>
        <right_joint>wheel_front_right_joint</right_joint>
        <wheel_separation>0.4</wheel_separation>
        <wheel_diameter>0.3</wheel_diameter>
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>1.0</max_wheel_acceleration>
        <odometrySource>encoder</odometrySource>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
      </plugin> -->
  <plugin
    filename="gz-sim-diff-drive-system"
    name="gz::sim::systems::DiffDrive">
    <left_joint>wheel_front_left_joint</left_joint>
    <right_joint>wheel_front_right_joint</right_joint>
    <wheel_separation>0.30</wheel_separation>
    <wheel_radius>0.05</wheel_radius>
    <topic>cmd_vel</topic>
    <odom_topic>odom</odom_topic>
</plugin>
</gazebo>




