    <!-- SENSORS -->
    <gazebo reference="base_link-v1">

    <sensor name="imu_sensor_base" type="imu">
        
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>

        <imu>
        <angular_velocity>
            <x>
            <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0002</stddev>
            </noise>
            </x>
        </angular_velocity>

        <linear_acceleration>
            <x>
            <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>0.0002</stddev>
            </noise>
            </x>
        </linear_acceleration>
        </imu>

        <!-- <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
