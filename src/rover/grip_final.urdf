<?xml version='1.0'?>
<robot name="grip">
    <link name="base_footprint"/>
    <link name="base_link">
        <inertial>
            <origin xyz="6.339725961573867e-17 3.1698629807869336e-17 0.048562887575206215" rpy="0.0 0.0 0.0" />
            <mass value="20.0" />
            <inertia ixx="0.5" iyy="0.5" izz="0.5" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="base_link_visual">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://rover/meshes/base_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="base_link_collision">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://rover/meshes/base_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="wheel_right">
        <inertial>
            <origin xyz="5.790023100122029e-18 5.790023100122029e-18 0.024999999999999967" rpy="0.0 -0.0 0.0" />
            <mass value="0.5" />
            <inertia ixx="0.0004" iyy="0.0004" izz="0.0006" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="wheel_right_visual">
            <origin xyz="0.0 0.0 -0.15" rpy="1.5707963267948966 -0.0 3.141592653589793" />
            <geometry>
                <mesh filename="package://rover/meshes/wheel_right.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="wheel_right_collision">
            <origin xyz="0.0 0.0 -0.15" rpy="1.5707963267948966 -0.0 3.141592653589793" />
            <geometry>
                <mesh filename="package://rover/meshes/wheel_right.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="arm_base">
        <inertial>
            <origin xyz="-2.199563811763958e-17 -1.2210031939763142e-33 0.026952474500458515" rpy="0.0 -0.0 0.0" />
            <mass value="1.0" />
            <inertia ixx="0.006" iyy="0.006" izz="0.01" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="arm_base_visual">
            <origin xyz="0.0 0.0 -0.1" rpy="0.0 -0.0 -1.5707963267948966" />
            <geometry>
                <mesh filename="package://rover/meshes/arm_base.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="arm_base_collision">
            <origin xyz="0.0 0.0 -0.1" rpy="0.0 -0.0 -1.5707963267948966" />
            <geometry>
                <mesh filename="package://rover/meshes/arm_base.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="wheel_left">
        <inertial>
            <origin xyz="-1.1580046200244058e-17 5.790023100122029e-18 0.025" rpy="0.0 -0.0 0.0" />
            <mass value="0.5" />
            <inertia ixx="0.0004" iyy="0.0004" izz="0.0006" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="wheel_left_visual">
            <origin xyz="0.0 0.0 -0.15" rpy="-1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://rover/meshes/wheel_left.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="wheel_left_collision">
            <origin xyz="0.0 0.0 -0.15" rpy="-1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://rover/meshes/wheel_left.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="bicep">
        <inertial>
            <origin xyz="0.01000000000000034 0.00012217298561360224 -0.06999989338392851" rpy="0.0 -0.0 0.0" />
            <mass value="0.18" />
            <inertia ixx="0.0005" iyy="0.00045" izz="0.0" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="bicep_visual">
            <origin xyz="0.009999999999999258 -0.00029670582220269636 0.1699997410752572" rpy="3.141592653589789 -0.001745329251994547 1.5707963267948968" />
            <geometry>
                <mesh filename="package://rover/meshes/bicep.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="bicep_collision">
            <origin xyz="0.009999999999999258 -0.00029670582220269636 0.1699997410752572" rpy="3.141592653589789 -0.001745329251994547 1.5707963267948968" />
            <geometry>
                <mesh filename="package://rover/meshes/bicep.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="forearm">
        <inertial>
            <origin xyz="0.010000000000000227 0.00016284760519322817 -0.09330240499009876" rpy="0.0 -0.0 0.0" />
            <mass value="0.25" />
            <inertia ixx="0.00084" iyy="0.00085" izz="0.0" ixy="0.0" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="forearm_visual">
            <origin xyz="0.010000000000000626 -0.3099995238143494 -0.0005410550255683155" rpy="-2.7218424594674333e-12 -1.5690509975429021 -1.5707963267920277" />
            <geometry>
                <mesh filename="package://rover/meshes/forearm.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="forearm_collision">
            <origin xyz="0.010000000000000626 -0.3099995238143494 -0.0005410550255683155" rpy="-2.7218424594674333e-12 -1.5690509975429021 -1.5707963267920277" />
            <geometry>
                <mesh filename="package://rover/meshes/forearm.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="claw1">
        <inertial>
            <origin xyz="-0.06406826194246286 0.03048382608604346 0.004946802055780175" rpy="0.0 -0.0 -2.340440257922764e-68" />
            <mass value="0.03" />
            <inertia ixx="0.0" iyy="0.0" izz="0.00004" ixy="0.000005" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="claw1_visual">
            <origin xyz="0.18500000000000189 -0.010549760408227452 -0.31498206814117546" rpy="-0.0017453292519941735 -4.672600714409454e-16 4.688058806876544e-15" />
            <geometry>
                <mesh filename="package://rover/meshes/claw1.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="claw1_collision">
            <origin xyz="0.18500000000000189 -0.010549760408227452 -0.31498206814117546" rpy="-0.0017453292519941735 -4.672600714409454e-16 4.688058806876544e-15" />
            <geometry>
                <mesh filename="package://rover/meshes/claw1.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="claw2">
        <inertial>
            <origin xyz="-0.06406826194246304 -0.03048382608604481 0.004946802055781312" rpy="0.0 -0.0 -2.340440257922764e-68" />
            <mass value="0.03" />
            <inertia ixx="0.0" iyy="0.0" izz="0.00004" ixy="0.000005" iyz="0.0" ixz="0.0" />
        </inertial>
        <visual name="claw2_visual">
            <origin xyz="0.18499999999999944 0.010549760408228312 -0.3149820681411722" rpy="0.0017453292519924357 -1.3609054026829438e-15 5.048881289879693e-15" />
            <geometry>
                <mesh filename="package://rover/meshes/claw2.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>
        <collision name="claw2_collision">
            <origin xyz="0.18499999999999944 0.010549760408228312 -0.3149820681411722" rpy="0.0017453292519924357 -1.3609054026829438e-15 5.048881289879693e-15" />
            <geometry>
                <mesh filename="package://rover/meshes/claw2.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>
    </link>
    <link name="camera_link">

        <inertial>
            <mass value="0.1"/>
            <inertia 
            ixx="0.0001" iyy="0.0001" izz="0.0001"
            ixy="0.0" ixz="0.0" iyz="0.0"/>
        </inertial>

        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
            <box size="0.03 0.03 0.03"/>
            </geometry>
            <material name="Black">
            <color rgba="0 0 0 1"/>
            </material>
        </visual>

    </link>

    <!--JOINTS-->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>
    <joint name="base_link_Revolute-8" type="continuous">
        <origin xyz="0.0 0.15 0.0" rpy="1.5707963267948966 -0.0 3.141592653589793" />
        <parent link="base_link" />
        <child link="wheel_right" />
        <limit lower="-1000" upper="1000" effort="50" velocity="20"/>
        <axis xyz="0.0 0.0 -1.0" />
    </joint>
    <joint name="base_link_Revolute-9" type="continuous">
        <origin xyz="0.0 -0.15 0.0" rpy="1.5707963267948966 -0.0 0.0" />
        <parent link="base_link" />
        <child link="wheel_left" />
        <limit lower="-1000" upper="1000" effort="50" velocity="20"/>
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="base_link_Revolute-10" type="continuous">
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 1.57" />
        <parent link="base_link" />
        <child link="arm_base" />
        <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="arm_base_Revolute-11" type="continuous">
        <origin xyz="-0.01 0.0 0.07" rpy="-1.5707963267948966 -0.0 0.0" />
        <parent link="arm_base" />
        <child link="bicep" />
        <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
        <axis xyz="1.0 0.0 0.0" />
    </joint>
    <joint name="bicep_Revolute-12" type="continuous">
        <origin xyz="0.0 0.0002443500000000043 -0.13999979" rpy="-3.141592653589793 -0.0 -2.168404344971009e-19" />
        <parent link="bicep" />
        <child link="forearm" />
        <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
        <axis xyz="-1.0 0.0 0.0" />
    </joint>
    <joint name="forearm_Revolute-13" type="continuous">
        <origin xyz="-0.01 0.005331609999999998 -0.18999099000000005" rpy="-1.5707963267948966 4.977565941268812e-31 0.0" />
        <parent link="forearm" />
        <child link="claw2" />
        <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
        <axis xyz="0.0 0.0 0.1" />
    </joint>
    <joint name="forearm_Revolute-14" type="continuous">
        <origin xyz="0.03 0.005331609999999998 -0.18999099000000005" rpy="1.5707963267948966 -4.977565941268812e-31 3.141592653589793" />
        <parent link="forearm" />
        <child link="claw1" />
        <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
        <axis xyz="0.0 0.0 0.1" />
    </joint>
    <joint name="camera_joint" type="fixed">
        <parent link="forearm"/>
        <child link="camera_link"/>
        <origin xyz="0.01 -0.04 -0.14" rpy="1.57 1.57 0"/>
    </joint>

    <!-- DIFFERENTIAL DRIVE PLUGIN -->
<gazebo>
  <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

    <left_joint>base_link_Revolute-9</left_joint>
    <right_joint>base_link_Revolute-8</right_joint>

    <wheel_separation>0.35</wheel_separation>
    <wheel_diameter>0.04</wheel_diameter>

    <max_wheel_torque>20.0</max_wheel_torque>
    <max_wheel_acceleration>0.5</max_wheel_acceleration>

    <publish_odom>true</publish_odom>
    <publish_odom_tf>true</publish_odom_tf>
    <publish_wheel_tf>true</publish_wheel_tf>

    <odometry_frame>odom</odometry_frame>
    <robot_base_frame>base_link</robot_base_frame>

  </plugin>
</gazebo>

<gazebo reference="camera_link">
  <sensor name="camera" type="camera">
    <update_rate>30</update_rate>

    <camera>
      <horizontal_fov>1.3962634</horizontal_fov>
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.05</near>
        <far>10.0</far>
      </clip>
    </camera>

    <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
      <ros>
        <namespace>/camera</namespace>
      </ros>
      <frame_name>camera_link</frame_name>
    </plugin>

  </sensor>
</gazebo>

<ros2_control name="ArmSystem" type="system">
  <hardware>
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
  </hardware>

  <joint name="base_link_Revolute-10">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="arm_base_Revolute-11">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="bicep_Revolute-12">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="forearm_Revolute-13">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="forearm_Revolute-14">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

</ros2_control>

<gazebo>
  <plugin name="gazebo_ros2_control"
          filename="libgazebo_ros2_control.so">
          <parameters>/home/aanimesh/pnp/install/rover/share/rover/config/arm_controllers.yaml</parameters>
  </plugin>
</gazebo>

</robot>